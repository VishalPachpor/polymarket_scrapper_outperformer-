# --------------------------------------------------------------------
# Copy-trader configuration
# --------------------------------------------------------------------

# Telegram alerts (required to receive trade notifications)
# 1. Create a bot: message @BotFather on Telegram → /newbot → copy token
# 2. Get your chat id: message @userinfobot or hit
#    https://api.telegram.org/bot<TOKEN>/getUpdates after sending your bot a message
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Copy-trader behavior
COPY_TRADER_POLL_INTERVAL=1.5
COPY_TRADER_FETCH_LIMIT=20
COPY_TRADER_DRY_RUN=true            # set to "false" only after validating alerts
COPY_TRADER_ENABLE_EXECUTION=false  # set to "true" to wire CLOB executor (still respects DRY_RUN)
COPY_TRADER_ONLY_BUYS=false         # phase-1 mode: only mirror opens
COPY_TRADER_MIN_NOTIONAL=25         # skip trades below $25 notional
COPY_TRADER_EVENT_PREFIXES=cricipl- # comma-separated slug prefixes to allow; empty = all categories

# Optional watchlist override (comma-separated: addr:pseudo:weight:size_pct:max_usdc)
# Leave unset to use the bundled defaults (Rectangular-Irony, Zigzag-Logistics, etc.)
# COPY_TRADER_WATCHLIST=0x82ff01408b945af138d3c4619dcf876387d52b09:Rectangular-Irony:0.5:0.10:200

# --------------------------------------------------------------------
# CLOB execution (only needed if COPY_TRADER_ENABLE_EXECUTION=true)
# --------------------------------------------------------------------

# Polymarket account credentials — derive via Account Settings → API Keys
POLYMARKET_FUNDER=                  # your proxy wallet address (0x...)
POLYMARKET_PRIVATE_KEY=             # private key of the EOA controlling the proxy
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# --------------------------------------------------------------------
# TIP infrastructure (already set elsewhere — only override if needed)
# --------------------------------------------------------------------
# TIP_DB_PATH=./tip_v1/tip_v1.sqlite3
# TIP_TRADES_API_URL=https://data-api.polymarket.com/trades
